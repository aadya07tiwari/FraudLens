# Rename this file to .env and fill in your own keys
GEMINI_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-flash-latest
ANTHROPIC_API_KEY=your_key_here
# Model used by both the Intent Agent and the NL-to-SQL Agent
CLAUDE_MODEL=claude-sonnet-4-5
# Path to the SQLite DB (created by data/setup_db.py)
DB_PATH=db/fraudlens_demo.db
# Safety cap: max rows any generated query is allowed to return
MAX_ROW_LIMIT=200
